          <mxGeometry x="185" y="970" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Flows -->
        <mxCell id="f1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A90E2;strokeWidth=2;" edge="1" parent="1" source="StartNode" target="InputAction">
