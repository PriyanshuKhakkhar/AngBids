<mxfile host="electron" modified="2026-03-05T08:45:00.000Z" agent="5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/21.6.8 Chrome/114.0.5735.289 Electron/25.5.0 Safari/537.36" version="21.6.8" type="device">
  <diagram id="LaraBidsBidFlow" name="Detailed Bid Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes -->
        <mxCell id="BidderLane" value="Bidder (User Interaction)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#EDF5FF;strokeColor=#4A90E2;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="360" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="EngineLane" value="Bidding Engine (Backend Transactional Logic)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#F8F9FA;strokeColor=#6C757D;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="400" height="1060" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="StartNode" value="" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="BidderLane">
          <mxGeometry x="165" y="50" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: Input -->
        <mxCell id="InputAction" value="Enter Manual Increment&lt;br&gt;OR Set Proxy Max Bid" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FFFFFF;strokeColor=#4A90E2;strokeWidth=2;" vertex="1" parent="BidderLane">
          <mxGeometry x="100" y="110" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Step 2: Lock -->
        <mxCell id="LockAction" value="DB Transaction Start&lt;br&gt;&amp; Pessimistic Lock&lt;br&gt;(lockForUpdate)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontStyle=1" vertex="1" parent="EngineLane">
          <mxGeometry x="120" y="190" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Step 3: Competing Proxy Decision -->
        <mxCell id="ProxyDecision" value="Other Active&lt;br&gt;Proxy Bids Exist?" style="rhombus;whiteSpace=wrap;html=1;rounded=0;fillColor=#FFF8E1;strokeColor=#FBC02D;strokeWidth=2;" vertex="1" parent="EngineLane">
          <mxGeometry x="135" y="300" width="130" height="90" as="geometry" />
        </mxCell>

        <!-- Scenario A: Proxy Competition -->
        <mxCell id="CompareAction" value="Compare Max Limits&lt;br&gt;&amp; Apply Min Increment" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FFFFFF;strokeColor=#6C757D;strokeWidth=2;" vertex="1" parent="EngineLane">
          <mxGeometry x="120" y="440" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Price Extension / Anti Sniping -->
        <mxCell id="SnipingDecision" value="Time Remaining&lt;br&gt;&lt; 2 Minutes?" style="rhombus;whiteSpace=wrap;html=1;rounded=0;fillColor=#FFF8E1;strokeColor=#FBC02D;strokeWidth=2;" vertex="1" parent="EngineLane">
          <mxGeometry x="135" y="540" width="130" height="90" as="geometry" />
        </mxCell>

        <mxCell id="ExtendAction" value="Trigger Anti-Sniping:&lt;br&gt;Extend End Time (+5m)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FDECEA;strokeColor=#D32F2F;strokeWidth=2;" vertex="1" parent="EngineLane">
          <mxGeometry x="120" y="670" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Commit -->
        <mxCell id="CommitAction" value="Update Current Price&lt;br&gt;&amp; Commit Transaction" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontStyle=1" vertex="1" parent="EngineLane">
          <mxGeometry x="120" y="770" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Notification -->
