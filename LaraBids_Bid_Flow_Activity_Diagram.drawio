        <!-- Outbid Legend / Micro Note -->
        <mxCell id="Note" value="Note: Manual increments &lt;br&gt;override proxies if higher &lt;br&gt;limit is met." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9C4;strokeColor=#FBC02D;" vertex="1" parent="BidderLane">
