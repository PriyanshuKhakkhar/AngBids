        <mxCell id="f5_no" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D32F2F;strokeWidth=2;labelBackgroundColor=#FDECEA;fontColor=#D32F2F;fontStyle=1" edge="1" parent="EngineLane" source="ProxyDecision" target="SnipingDecision">
          <mxGeometry x="-0.85" relative="1" as="geometry">
