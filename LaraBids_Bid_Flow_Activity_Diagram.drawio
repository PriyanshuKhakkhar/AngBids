        <mxCell id="f4_yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2E7D32;strokeWidth=2;labelBackgroundColor=#E8F5E9;fontColor=#2E7D32;fontStyle=1" edge="1" parent="EngineLane" source="ProxyDecision" target="CompareAction">
          <mxGeometry relative="1" as="geometry" />
